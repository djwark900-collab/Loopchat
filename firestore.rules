rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email in ['admin@gmail.com', 'zaxoking499@gmail.com']
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. User Profiles
    function isValidUser(data) {
      // Must contain core fields
      let coreKeys = ['id', 'username', 'fullName', 'avatarUrl', 'coins', 'level', 'xp'];
      return data.keys().hasAll(coreKeys)
        && data.id is string && data.id.size() <= 128
        && data.username is string && data.username.size() <= 100
        && data.fullName is string && data.fullName.size() <= 150
        && data.avatarUrl is string && data.avatarUrl.size() <= 2000
        && data.coins is int
        && data.level is int
        && data.xp is int
        // Optional fields check
        && (!('bio' in data) || data.bio is string)
        && (!('diamonds' in data) || data.diamonds is int)
        && (!('xpToNextLevel' in data) || data.xpToNextLevel is int)
        && (!('followers' in data) || data.followers is int)
        && (!('following' in data) || data.following is int)
        && (!('createdAt' in data) || data.createdAt is string)
        && (!('identificationCode' in data) || data.identificationCode is string);
    }

    match /users/{userId} {
      // Users can read any profile (social) but only edit their own
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    // 3. Streamers (Live Sessions)
    function isValidStreamer(data) {
       return data.keys().hasAll(['username', 'title', 'isLive', 'creatorId', 'createdAt'])
        && data.username is string
        && data.title is string
        && data.isLive is bool
        && data.creatorId is string
        && data.createdAt is timestamp;
    }

    match /streamers/{streamerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isValidStreamer(incoming()) && incoming().creatorId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Allow anyone to increment viewers (public interaction)
        (incoming().diff(existing()).affectedKeys().hasOnly(['viewersCount'])) ||
        // Allow owner or admin to edit
        (isOwner(existing().creatorId) || isAdmin())
      );
      allow delete: if isSignedIn() && (isOwner(existing().creatorId) || isAdmin());
    }

    // 4. Gifts
    match /gifts/{giftId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && isOwner(existing().creatorId));
    }

    // 5. Coin Codes
    match /coin_codes/{codeId} {
      allow get: if true;
      allow create: if isSignedIn(); // Seeding or Admin
      allow update, delete: if isAdmin();
    }
  }
}
