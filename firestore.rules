rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email in ['admin@gmail.com', 'zaxoking499@gmail.com']
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isNumeric(val) { return val is int || val is float; }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. User Profiles
    function isValidUser(data) {
      // Must contain core fields
      let coreKeys = ['id', 'username', 'fullName', 'avatarUrl', 'coins', 'level', 'xp'];
      return data.keys().hasAll(coreKeys)
        && data.id is string && data.id.size() <= 128
        && data.username is string && data.username.size() <= 100
        && data.fullName is string && data.fullName.size() <= 150
        && data.avatarUrl is string && data.avatarUrl.size() <= 3000000
        && isNumeric(data.coins)
        && isNumeric(data.level)
        && isNumeric(data.xp)
        // Optional fields check - resilient to null or missing values
        && (!('bio' in data) || data.bio == null || (data.bio is string && data.bio.size() <= 2000))
        && (!('diamonds' in data) || data.diamonds == null || isNumeric(data.diamonds))
        && (!('xpToNextLevel' in data) || data.xpToNextLevel == null || isNumeric(data.xpToNextLevel))
        && (!('followers' in data) || data.followers == null || isNumeric(data.followers))
        && (!('following' in data) || data.following == null || isNumeric(data.following))
        && (!('createdAt' in data) || data.createdAt == null || data.createdAt is string)
        && (!('identificationCode' in data) || data.identificationCode == null || data.identificationCode is string)
        && (!('email' in data) || data.email == null || (data.email is string && data.email.size() <= 320))
        && (!('activeFrameId' in data) || data.activeFrameId == null || (data.activeFrameId is string && data.activeFrameId.size() <= 128))
        && (!('unlockedFrames' in data) || data.unlockedFrames == null || data.unlockedFrames is list)
        && (!('countryFlag' in data) || data.countryFlag == null || (data.countryFlag is string && data.countryFlag.size() <= 20))
        && (!('gender' in data) || data.gender == null || (data.gender is string && data.gender.size() <= 20))
        && (!('likesCount' in data) || data.likesCount == null || isNumeric(data.likesCount))
        && (!('friendsCount' in data) || data.friendsCount == null || isNumeric(data.friendsCount))
        && (!('referralCode' in data) || data.referralCode == null || (data.referralCode is string && data.referralCode.size() <= 128))
        && (!('watchedCount' in data) || data.watchedCount == null || isNumeric(data.watchedCount))
        && (!('giftsSentCount' in data) || data.giftsSentCount == null || isNumeric(data.giftsSentCount))
        && (!('equippedCount' in data) || data.equippedCount == null || isNumeric(data.equippedCount))
        && (!('claimedMissions' in data) || data.claimedMissions == null || data.claimedMissions is list);
    }

    match /users/{userId} {
      // Users can read any profile (social) but only edit their own
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    // 3. Streamers (Live Sessions)
    function isValidStreamer(data) {
       return data.keys().hasAll(['username', 'title', 'isLive', 'creatorId', 'createdAt'])
        && data.username is string && data.username.size() <= 200
        && data.title is string && data.title.size() <= 500
        && data.isLive is bool
        && data.creatorId is string && data.creatorId.size() <= 128
        && (data.createdAt is timestamp || data.createdAt == request.time);
    }

    match /streamers/{streamerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isValidStreamer(incoming()) && incoming().creatorId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Allow anyone to increment viewers (public interaction)
        (incoming().diff(existing()).affectedKeys().hasOnly(['viewersCount'])) ||
        // Allow owner or admin to edit
        (isOwner(existing().creatorId) || isAdmin())
      );
      allow delete: if isSignedIn() && (isOwner(existing().creatorId) || isAdmin());
    }

    // 4. Gifts
    match /gifts/{giftId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && isOwner(existing().creatorId));
    }

    // 5. Coin Codes
    match /coin_codes/{codeId} {
      allow get: if true;
      allow create: if isSignedIn(); // Seeding or Admin
      allow update, delete: if isAdmin();
    }
  }
}
