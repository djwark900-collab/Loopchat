rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 3. Primitive Definition
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isOwner(creatorId) { return isSignedIn() && creatorId == request.auth.uid; }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Streamers ---
    function isValidStreamer(data) {
      return data.keys().hasAll(['username', 'title', 'isLive', 'creatorId', 'createdAt'])
        && data.username is string && data.username.size() <= 50
        && data.title is string && data.title.size() <= 150
        && data.isLive is bool
        && data.creatorId is string && data.creatorId == request.auth.uid
        && data.createdAt == request.time
        && (!('viewersCount' in data) || data.viewersCount is int >= 0)
        && (!('level' in data) || data.level is int >= 1)
        && (!('startingCoins' in data) || data.startingCoins is int >= 0)
        && (!('category' in data) || data.category is string && data.category.size() <= 50)
        && (!('videoFeedType' in data) || data.videoFeedType is string && data.videoFeedType.size() <= 100)
        && (!('customVideoUrl' in data) || data.customVideoUrl is string && data.customVideoUrl.size() <= 2000)
        && (!('fullName' in data) || data.fullName is string && data.fullName.size() <= 100)
        && (!('avatarUrl' in data) || data.avatarUrl is string && data.avatarUrl.size() <= 2000);
    }

    match /streamers/{streamerId} {
      allow read: if true; // Streams are public
      allow create: if isSignedIn() && isValidId(streamerId) && isValidStreamer(incoming()) && incoming().keys().size() <= 15;
      allow update: if isSignedIn() && isValidId(streamerId) && isOwner(existing().creatorId) 
        && isValidStreamer(incoming())
        && incoming().creatorId == existing().creatorId
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['viewersCount', 'title', 'category', 'isLive', 'level', 'startingCoins', 'videoFeedType', 'customVideoUrl', 'fullName', 'avatarUrl', 'username'])
        );
      allow delete: if isSignedIn() && isValidId(streamerId) && isOwner(existing().creatorId);
    }

    // --- Gifts ---
    function isValidGift(data) {
      return data.keys().hasAll(['name', 'icon', 'cost', 'creatorId', 'createdAt'])
        && data.name is string && data.name.size() <= 50
        && data.icon is string && data.icon.size() <= 10
        && data.cost is int && data.cost >= 0
        && data.creatorId is string && data.creatorId == request.auth.uid
        && data.createdAt == request.time
        && (!('effect' in data) || data.effect is string && data.effect.size() <= 100)
        && (!('category' in data) || data.category is string && data.category.size() <= 50)
        && (!('videoFeedTheme' in data) || data.videoFeedTheme is string && data.videoFeedTheme.size() <= 100)
        && (!('customVideoUrl' in data) || data.customVideoUrl is string && data.customVideoUrl.size() <= 2000);
    }

    match /gifts/{giftId} {
      allow read: if true; // Gifts are public
      allow create: if isSignedIn() && isValidId(giftId) && isValidGift(incoming()) && incoming().keys().size() <= 10;
      allow update: if isSignedIn() && isValidId(giftId) && isOwner(existing().creatorId)
        && isValidGift(incoming())
        && incoming().creatorId == existing().creatorId
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'icon', 'cost', 'effect', 'category', 'videoFeedTheme', 'customVideoUrl'])
        );
      allow delete: if isSignedIn() && isValidId(giftId) && isOwner(existing().creatorId);
    }
  }
}
