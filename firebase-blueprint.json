{
  "entities": {
    "Streamer": {
      "title": "Streamer",
      "description": "Represents a live stream session entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "fullName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "level": { "type": "number" },
        "viewersCount": { "type": "number" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "isLive": { "type": "boolean" },
        "startingCoins": { "type": "number" },
        "videoFeedType": { "type": "string" },
        "customVideoUrl": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "title", "isLive", "creatorId"]
    },
    "Gift": {
      "title": "Gift",
      "description": "Represents a virtual gift that can be sent in streams.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "cost": { "type": "number" },
        "effect": { "type": "string" },
        "category": { "type": "string" },
        "videoFeedTheme": { "type": "string" },
        "customVideoUrl": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "icon", "cost", "creatorId"]
    }
  },
  "firestore": {
    "/streamers/{streamerId}": {
      "schema": "Streamer",
      "description": "Collection of all live streams."
    },
    "/gifts/{giftId}": {
      "schema": "Gift",
      "description": "Collection of custom gifts accessible to all users."
    }
  }
}
