{
  "entities": {
    "User": {
      "title": "User",
      "description": "Creator User Profile of LoopChat",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The user ID (usually matches authentication uid)" },
        "username": { "type": "string", "description": "Unique username starting with @" },
        "fullName": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "description": "Email address of the user" },
        "avatarUrl": { "type": "string", "description": "Base64 encoded or URL of user avatar" },
        "bio": { "type": "string", "description": "Creator bio representation" },
        "coins": { "type": "integer", "description": "Total coins in the user's wallet" },
        "level": { "type": "integer", "description": "Current creator level" },
        "xp": { "type": "integer", "description": "Experience points" },
        "xpToNextLevel": { "type": "integer", "description": "Experience points required for next level" },
        "followers": { "type": "integer", "description": "Number of followers" },
        "following": { "type": "integer", "description": "Number of following users" },
        "createdAt": { "type": "string", "description": "Creation timestamp in local or ISO format" },
        "activeFrameId": { "type": "string", "description": "Id of active equipped frame" },
        "unlockedFrames": { "type": "array", "items": { "type": "string" }, "description": "Purchased/Unlocked frame list" },
        "countryFlag": { "type": "string", "description": "Creator country flag emoji" },
        "gender": { "type": "string", "description": "Specified or selected creator gender display" },
        "likesCount": { "type": "integer", "description": "Simulated profile likes counter" },
        "friendsCount": { "type": "integer", "description": "Simulated profile friends counter" },
        "referralCode": { "type": "string", "description": "Referral code entered by the user" },
        "identificationCode": { "type": "string", "description": "Pristine computed read-only unique ID of user" }
      },
      "required": ["id", "username", "fullName", "email", "avatarUrl", "coins", "level", "xp", "xpToNextLevel", "followers", "following"]
    },
    "CoinCode": {
      "title": "CoinCode",
      "description": "Single-use coin codes generated by Admin",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "Unique alphanumeric coupon code" },
        "coins": { "type": "integer", "description": "Coin amount this code awards on redemption" },
        "createdAt": { "type": "string", "description": "ISO timestamp of code creation" }
      },
      "required": ["code", "coins", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Users/Creators path in Firestore, indexed by Auth system UID"
    },
    "coin_codes/{codeId}": {
      "schema": "CoinCode",
      "description": "Admin generated single-use coins codes collection"
    }
  }
}
